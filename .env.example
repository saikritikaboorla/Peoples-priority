# Database
DATABASE_URL="postgresql://feedback:feedback@localhost:5432/feedback_platform?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Object Storage (MinIO / S3-compatible)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="feedback-media"
S3_REGION="us-east-1"

# AI Services (optional — platform works with mock AI when unset)
OPENAI_API_KEY=""
WHISPER_API_URL=""

# Backend
PORT=3001
JWT_SECRET="change-me-in-production"
CORS_ORIGIN="http://localhost:3000"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
